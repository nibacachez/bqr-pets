<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo del logo -->
  <rect width="40" height="40" rx="8" fill="#101E3A"/>
  
  <!-- QR Pattern -->
  <g id="qr-pattern">
    <!-- Esquina Superior Izquierda -->
    <rect width="8" height="8" fill="#00C4CC"/>
    <rect x="2" y="2" width="4" height="4" fill="#101E3A"/>
    
    <!-- Esquina Superior Derecha -->
    <rect x="32" width="8" height="8" fill="#00C4CC"/>
    <rect x="34" y="2" width="4" height="4" fill="#101E3A"/>
    
    <!-- Esquina Inferior Izquierda -->
    <rect y="32" width="8" height="8" fill="#00C4CC"/>
    <rect x="2" y="34" width="4" height="4" fill="#101E3A"/>
    
    <!-- Puntos QR aleatorios en el centro -->
    <rect x="16" y="14" width="2" height="2" fill="#00C4CC"/>
    <rect x="20" y="16" width="2" height="2" fill="#00C4CC"/>
    <rect x="18" y="20" width="2" height="2" fill="#00C4CC"/>
    <rect x="14" y="18" width="2" height="2" fill="#00C4CC"/>
    <rect x="22" y="22" width="2" height="2" fill="#00C4CC"/>
  </g>
</svg>
